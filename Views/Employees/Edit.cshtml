@model EmployeesManagement.Models.Employee
@{ ViewData["Title"]="Edit"; }
<div class="card"><div class="card-header"><h3>Edit Employee</h3></div>
<div class="card-body"><form asp-action="Edit">
@if("Edit"=="Edit"){<input type="hidden" asp-for="Id"/>}
<div class="row">
<div class="col-md-6 form-group"><label asp-for="EmpNumber"></label><input asp-for="EmpNumber" class="form-control"/><span asp-validation-for="EmpNumber" class="text-danger"></span></div>
<div class="col-md-6 form-group"><label asp-for="FirstName"></label><input asp-for="FirstName" class="form-control"/></div>
<div class="col-md-6 form-group"><label asp-for="MiddleName"></label><input asp-for="MiddleName" class="form-control"/></div>
<div class="col-md-6 form-group"><label asp-for="LastName"></label><input asp-for="LastName" class="form-control"/></div>
<div class="col-md-6 form-group"><label asp-for="PhoneNumber"></label><input asp-for="PhoneNumber" class="form-control"/></div>
<div class="col-md-6 form-group"><label asp-for="EmailAddress"></label><input asp-for="EmailAddress" class="form-control"/></div>
<div class="col-md-6 form-group"><label asp-for="Country"></label><input asp-for="Country" class="form-control"/></div>
<div class="col-md-6 form-group"><label asp-for="DateOfBirth"></label><input asp-for="DateOfBirth" type="date" class="form-control"/></div>
<div class="col-md-12 form-group"><label asp-for="Address"></label><input asp-for="Address" class="form-control"/></div>
<div class="col-md-6 form-group"><label asp-for="Department"></label><input asp-for="Department" class="form-control"/></div>
<div class="col-md-6 form-group"><label asp-for="Designation"></label><input asp-for="Designation" class="form-control"/></div>
<div class="col-md-6 form-group"><label asp-for="Function"></label><select asp-for="Function" asp-items="Html.GetEnumSelectList<EmployeesManagement.Models.EmployeeFunction>()" class="form-control"></select></div>
</div>
<button type="submit" class="btn btn-primary">Save</button>
<a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form></div></div>
