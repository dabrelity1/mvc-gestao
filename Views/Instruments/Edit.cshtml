@model EmployeesManagement.Models.Instrument
@{ ViewData["Title"]="Edit Instrument"; }
<div class="card"><div class="card-header"><h3>Edit Instrument</h3></div>
<div class="card-body"><form asp-action="Edit">
<input type="hidden" asp-for="Id"/>
<div class="row">
<div class="col-md-6 form-group"><label asp-for="TipoInstrumento"></label><input asp-for="TipoInstrumento" class="form-control"/><span asp-validation-for="TipoInstrumento" class="text-danger"></span></div>
<div class="col-md-6 form-group"><label asp-for="Instrumento"></label><input asp-for="Instrumento" class="form-control"/><span asp-validation-for="Instrumento" class="text-danger"></span></div>
<div class="col-md-6 form-group"><div class="form-check mt-4"><input asp-for="UsaCordas" class="form-check-input"/><label asp-for="UsaCordas" class="form-check-label"></label></div></div>
</div>
<button type="submit" class="btn btn-primary">Save</button>
<a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form></div></div>
